    "@types/node": "22.8.7",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "css-loader": "7.1.2",
    "html-webpack-plugin": "5.6.3",
    "identity-obj-proxy": "3.0.0",
    "jest": "29.7.0",
    "jest-environment-jsdom": "29.7.0",
    "style-loader": "4.0.0",
    "ts-jest": "29.2.5",
